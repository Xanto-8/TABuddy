generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ClassGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users             User[]
  knowledgeEntries  KnowledgeBaseEntry[]
}

model User {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String
  displayName String   @default("")
  role        String   @default("student")
  avatar      String   @default("")
  settings    String   @default("{}")
  hasReadGuide  Boolean @default(false)
  hasFillSurvey Boolean @default(false)
  lastActiveAt  DateTime?
  lastLoginIp      String   @default("")
  lastLoginCountry String   @default("")
  lastLoginCity    String   @default("")
  lastLoginRegion  String   @default("")
  classGroupId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classGroup ClassGroup? @relation(fields: [classGroupId], references: [id], onDelete: SetNull)

  classes          Class[]
  students         Student[]
  classSchedules   ClassSchedule[]
  courseTasks      CourseTask[]
  taskTemplates    TaskTemplate[]
  homeworkAssessments HomeworkAssessment[]
  quizRecords      QuizRecord[]
  feedbackRecords  FeedbackRecord[]
  feedbackHistory  FeedbackHistoryEntry[]
  userFeedbacks    UserFeedback[]
  absenceRecords   AbsenceRecord[]
  workflowTemplates WorkflowTemplate[]
  workflowTodos    WorkflowTodo[]
  notifications    Notification[]
  pushLogs         PushLog[]
  reminderConfigs  ReminderConfig[]
  knowledgeEntries KnowledgeBaseEntry[]
  userStores       UserStore[]
  teacherBinds     TeacherAssistantBind[] @relation("TeacherBindRelation")
  assistantBinds   TeacherAssistantBind[] @relation("AssistantBindRelation")
  teacherRegCodes  TeacherRegCode[]
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")
}

model PublicKnowledgeItem {
  id          String   @id @default(cuid())
  title       String
  content     String
  category    String   @default("")
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Class {
  id            String   @id @default(cuid())
  name          String
  type          String   @default("")
  studentCount  Int      @default(0)
  color         String   @default("")
  courseTasks   String   @default("[]")
  taskTemplates String   @default("[]")
  scores        String   @default("[]")
  latestScore   String   @default("")
  accuracyTrend String   @default("[]")
  scheduleIds   String   @default("[]")
  studentIds    String   @default("[]")
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  schedules ClassSchedule[]
  students  Student[]
}

model ClassSchedule {
  id          String   @id @default(cuid())
  dayOfWeek   Int
  startTime   String
  endTime     String
  room        String   @default("")
  location    String   @default("")

  classId String
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Student {
  id             String   @id @default(cuid())
  name           String
  isKeyStudent   Boolean  @default(false)
  retestList     String   @default("[]")
  testAccuracy   String   @default("")
  quizCompletion String   @default("[]")
  notes          String   @default("")
  assessments    String   @default("[]")
  quizzes        String   @default("[]")
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  classId String
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CourseTask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  dueDate   String   @default("")
  priority  String   @default("medium")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classId String?
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaskTemplate {
  id     String @id @default(cuid())
  title  String
  type   String @default("")

  classId String?
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model HomeworkAssessment {
  id         String   @id @default(cuid())
  studentName String
  courseName  String   @default("")
  score      String   @default("")
  date       String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuizRecord {
  id         String   @id @default(cuid())
  studentName String
  courseName  String   @default("")
  score      String   @default("")
  date       String   @default("")
  type       String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackRecord {
  id          String   @id @default(cuid())
  studentName String
  courseName  String   @default("")
  content     String
  date        String   @default("")
  type        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackHistoryEntry {
  id        String   @id @default(cuid())
  content   String
  date      String   @default("")
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFeedback {
  id          String   @id @default(cuid())
  type        String   @default("bug")        // bug / suggestion / other
  description String
  screenshot  String   @default("")
  status      String   @default("pending")    // pending / resolved / closed
  reply       String   @default("")
  repliedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AbsenceRecord {
  id         String   @id @default(cuid())
  studentName String
  className  String   @default("")
  date       String
  type       String   @default("absent")
  reason     String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkflowTemplate {
  id        String   @id @default(cuid())
  name      String
  nodes     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkflowTodo {
  id         String   @id @default(cuid())
  title      String
  completed  Boolean  @default(false)
  dueDate    String   @default("")
  priority   String   @default("medium")
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String   @default("")
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushLog {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("")
  sentAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReminderConfig {
  id        String   @id @default(cuid())
  config    String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BannedIP {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String   @default("")
  bannedBy  String
  createdAt DateTime @default(now())
}

model KnowledgeBaseEntry {
  id        String   @id @default(cuid())
  scope     String   @default("personal")
  title     String
  content   String
  category  String   @default("")
  tags      String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  classGroupId String?
  classGroup  ClassGroup? @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
}

model UserStore {
  id      String @id @default(cuid())
  key     String
  value   String @default("")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model TeacherAssistantBind {
  id             String   @id @default(cuid())
  inviteCode     String
  status         String   @default("active") // active / unbinded
  validPeriod    String   @default("permanent") // permanent / 24h / 7d
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  bindedAt       DateTime?

  teacherId String
  teacher   User   @relation("TeacherBindRelation", fields: [teacherId], references: [id], onDelete: Cascade)

  assistantId String?
  assistant   User?  @relation("AssistantBindRelation", fields: [assistantId], references: [id], onDelete: SetNull)

  @@unique([teacherId, assistantId])
  @@index([inviteCode, status])
  @@index([teacherId, status])
  @@index([assistantId, status])
}

model TeacherRegCode {
  id        String   @id @default(cuid())
  code      String   @unique
  creatorId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([code, isActive])
  @@index([creatorId])
}
