# ============ 必填配置 ============

# 数据库连接 — 部署到 Vercel 时必须使用 PostgreSQL
# 推荐使用 Neon、Supabase、Vercel Postgres 或 Railway 等服务
# 格式: postgresql://用户名:密码@主机:端口/数据库名
# 示例: postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/tabuddy?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/tabuddy?sslmode=require

# DeepSeek API Key — 用于 AI 课程反馈生成、智能助教聊天等
# 获取方式：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key


# ============ 可选配置 ============

# 初始超级管理员密码（安全初始化）
# 设置后，调用 POST /api/admin/init-superadmin 可创建默认超管账号 admin
# 仅当数据库中没有任何超管时生效，初始化成功后建议移除该变量
# 本地开发可通过 npx prisma db seed 创建超管（用户名: admin, 密码: admin123）
INIT_SUPERADMIN_PASSWORD=your_superadmin_password

# DeepSeek Vision API Key — 用于学情反馈图片识别（多模态分析）
DEEPSEEK_VISION_API_KEY=your_deepseek_vision_api_key

# Imgur Client-ID — 用于公网图床照片上传
# 部署到 Vercel 时必须配置此变量，否则文件上传功能不可用
IMGUR_CLIENT_ID=your_imgur_client_id

# 企业微信应用消息推送配置（可选）
# WECOM_CORP_ID=你的企业ID
# WECOM_AGENT_SECRET=你的应用Secret
# WECOM_AGENT_ID=你的应用ID
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app


# ============ Vercel 部署说明 ============
# 部署到 Vercel 时，请在 Vercel Dashboard 中配置以下环境变量：
# Settings -> Environment Variables
#
# 必填变量（需要在 Vercel Dashboard 手动设置）：
# - DATABASE_URL → PostgreSQL 数据库连接字符串
# - DEEPSEEK_API_KEY → DeepSeek API Key
#
# 可选变量（按需设置）：
# - DEEPSEEK_VISION_API_KEY → DeepSeek Vision API Key
# - IMGUR_CLIENT_ID → Imgur 图床 Client-ID
# - NEXT_PUBLIC_APP_URL → 应用公网 URL（如 https://tabuddy.vercel.app）
#
# 以下变量由 Vercel 自动注入，无需手动设置：
# - NEXT_PUBLIC_API_BASE_URL → /api （已在 vercel.json 中定义）
# - NEXT_PUBLIC_API_URL → /api （已在 vercel.json 中定义）
# - VERCEL → 1
